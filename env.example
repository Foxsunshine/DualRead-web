# DualRead-web (Next.js Landing + Admin) — example env. Copy to `.env.local`.
# `.env*` is gitignored; this `env.example` IS committed.
#
# Naming convention (Next.js):
#   - `NEXT_PUBLIC_*`  → inlined into the browser bundle. NEVER a secret.
#   - everything else  → server-only (Route Handlers, Server Components,
#     Server Actions). Treat as secret.

# ───── Public (browser-visible) ─────────────────────────────────
# Backend base URL — Cloudflare Tunnel front for the FastAPI service.
NEXT_PUBLIC_BACKEND_URL=https://api.dualread.local

# ───── Server-only ──────────────────────────────────────────────
# Cloudflare Access JWT audience claim — the admin pages live behind
# Access; the Next route handler verifies the audience before forwarding.
CF_ACCESS_AUD=

# Langfuse keys for the admin observability widgets (Phase 5+).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
